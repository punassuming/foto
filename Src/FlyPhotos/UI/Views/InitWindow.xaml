<Window
    x:Class="FlyPhotos.UI.Views.InitWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:library="using:FlyPhotos.Services.Library"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>
    <Grid x:Name="MainLayout" Background="Transparent">
        <StackPanel Margin="20,10,20,20" Spacing="15">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <TextBlock x:Uid="TitleTextBlock" Style="{StaticResource TitleTextBlockStyle}" />
                <Button
                    x:Name="ButtonOpenSettings"
                    x:Uid="ButtonOpenSettings"
                    Grid.Column="1"
                    Click="ButtonOpenSettings_OnClick" />
            </Grid>
            <!--  File Interaction Area  -->
            <Border
                x:Name="DropArea"
                Height="150"
                Margin="0,30,0,0"
                AllowDrop="True"
                Background="Transparent"
                DragOver="DropArea_DragOver"
                Drop="DropArea_Drop">
                <Grid>
                    <!--  Dashed outline effect  -->
                    <Rectangle
                        RadiusX="8"
                        RadiusY="8"
                        Stroke="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                        StrokeDashArray="4 2"
                        StrokeThickness="3" />
                    <!--  Content: Text runs are now empty tags, populated by x:Uid  -->
                    <TextBlock
                        x:Uid="DropAreaTextBlock"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource SystemControlPageTextBaseHighBrush}"
                        TextAlignment="Center">
                        <Run x:Uid="DropAreaRun" />
                        <Hyperlink Click="OpenFileHyperlink_Click">
                            <Run x:Uid="OpenFileHyperlink" />
                        </Hyperlink>
                    </TextBlock>
                </Grid>
            </Border>
            <Border
                Margin="0,10,0,0"
                Padding="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock
                        x:Uid="LibrarySectionTitle"
                        Style="{StaticResource SubtitleTextBlockStyle}" />
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <TextBlock x:Uid="LibraryIndexedCountLabel" />
                        <TextBlock
                            x:Name="IndexedPhotoCountTextBlock"
                            Grid.Column="1"
                            Text="0" />
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <TextBlock x:Uid="LibraryStatusLabel" />
                        <TextBlock
                            x:Name="IndexingStatusTextBlock"
                            Grid.Column="1"
                            TextWrapping="Wrap" />
                    </Grid>
                    <TextBlock x:Uid="LibraryWatchedFoldersLabel" />
                    <TextBlock
                        x:Name="WatchedFoldersTextBlock"
                        TextWrapping="Wrap" />
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                        <TextBox
                            x:Name="SearchTextBox"
                            x:Uid="SearchTextBox"
                            TextChanged="SearchTextBox_OnTextChanged" />
                        <TextBox
                            x:Name="SearchDateTextBox"
                            x:Uid="SearchDateTextBox"
                            Grid.Column="1"
                            Width="130"
                            TextChanged="SearchDateTextBox_OnTextChanged" />
                        <ComboBox
                            x:Name="SearchRatingComboBox"
                            Grid.Column="2"
                            MinWidth="120"
                            SelectionChanged="SearchRatingComboBox_OnSelectionChanged">
                            <ComboBoxItem x:Uid="SearchRatingAnyItem" Tag="" />
                            <ComboBoxItem x:Uid="SearchRatingOneItem" Tag="1" />
                            <ComboBoxItem x:Uid="SearchRatingTwoItem" Tag="2" />
                            <ComboBoxItem x:Uid="SearchRatingThreeItem" Tag="3" />
                            <ComboBoxItem x:Uid="SearchRatingFourItem" Tag="4" />
                            <ComboBoxItem x:Uid="SearchRatingFiveItem" Tag="5" />
                        </ComboBox>
                    </Grid>
                    <ListView
                        x:Name="SearchResultsListView"
                        Height="180"
                        IsItemClickEnabled="True"
                        ItemClick="SearchResultsListView_OnItemClick"
                        SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="library:LibrarySearchResult">
                                <StackPanel Padding="0,6">
                                    <TextBlock Text="{x:Bind FileName}" />
                                    <TextBlock
                                        Opacity="0.75"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Text="{x:Bind FolderPath}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
            <!--  Instructions  -->
            <TextBlock
                x:Uid="RightClickInstruction"
                Margin="0,10,0,0"
                TextWrapping="Wrap" />
            <Border
                Margin="0,5"
                BorderBrush="Gray"
                BorderThickness="0,1,0,0" />
            <TextBlock x:Uid="DefaultViewerInstruction1" TextWrapping="Wrap" />
            <Border
                Margin="0,5"
                BorderBrush="Gray"
                BorderThickness="0,1,0,0" />
            <TextBlock x:Uid="DefaultViewerInstruction2" TextWrapping="Wrap" />
            <Border
                Margin="0,5"
                BorderBrush="Gray"
                BorderThickness="0,1,0,0" />
        </StackPanel>
    </Grid>
</Window>